# Security headers (all routes). Cache-Control is set per path below; last matching rule wins.
/*
  Content-Language: it
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# HTML: revalidate quickly, serve stale while updating
/
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/varieta/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/impara/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/italia/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/guide/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/glossario/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/gioca/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/diario/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/cerca/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/privacy/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/termini/*
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/feed.xml
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/sitemap.xml
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=86400

/llms.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

/favicon.svg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: image/svg+xml

/favicon.ico
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: image/x-icon

/favicon-16x16.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: image/png

/favicon-32x32.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: image/png

/apple-touch-icon.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: image/png

# Hashed static assets — must follow HTML rules so Cache-Control is not overwritten
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/config/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/pagefind/*
  Cache-Control: public, max-age=31536000, immutable
