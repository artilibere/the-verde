{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "document.base.schema.json",
  "title": "Base document envelope",
  "type": "object",
  "required": ["schema_version", "type", "slug", "meta", "body"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "type": {
      "type": "string",
      "enum": ["variety", "article", "glossary", "controversy", "hub", "page"]
    },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "meta": {
      "type": "object",
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "canonical_path": { "type": "string", "pattern": "^/" },
        "published": { "type": ["string", "null"] },
        "brief": { "type": "string" }
      },
      "additionalProperties": true
    },
    "seo": {
      "type": "object",
      "properties": {
        "robots": { "type": "string" },
        "og_type": { "type": "string" },
        "schema_org": {}
      },
      "additionalProperties": true
    },
    "navigation": {
      "type": "object",
      "properties": {
        "related_slugs": { "type": "array", "items": { "type": "string" } },
        "temi_kb": { "type": "array", "items": { "type": "string" } },
        "controversie": { "type": "array", "items": { "type": "string" } },
        "momenti": { "type": "array", "items": { "type": "string" } },
        "stagioni": { "type": "array", "items": { "type": "string" } },
        "percorso_tappa": { "type": ["string", "null"] },
        "explore_next": { "type": "array" },
        "badge_sblocco": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "taxonomy": { "type": "object" },
    "body": {
      "type": "object",
      "required": ["blocks"],
      "properties": {
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        }
      }
    }
  },
  "$defs": {
    "span": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["text", "strong", "em", "link"] },
        "value": { "type": "string" },
        "href": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "link" } } },
          "then": { "required": ["value", "href"] }
        },
        {
          "if": {
            "properties": { "type": { "enum": ["text", "strong", "em"] } }
          },
          "then": { "required": ["value"] }
        }
      ]
    },
    "block": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": [
            "heading",
            "paragraph",
            "list",
            "sensory_profile",
            "brew_params",
            "equipment",
            "steps",
            "errors",
            "callout",
            "pairings",
            "faq",
            "related_links",
            "level_section",
            "positions"
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "heading" } } },
          "then": {
            "required": ["level", "spans"],
            "properties": {
              "level": { "type": "integer", "minimum": 1, "maximum": 3 },
              "spans": { "type": "array", "items": { "$ref": "#/$defs/span" } }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "paragraph" } } },
          "then": {
            "required": ["spans"],
            "properties": {
              "spans": { "type": "array", "items": { "$ref": "#/$defs/span" } }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "list" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "ordered": { "type": "boolean" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["spans"],
                  "properties": {
                    "spans": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/span" }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "sensory_profile" } } },
          "then": {
            "required": ["aspetto", "aroma", "gusto", "retrogusto"],
            "properties": {
              "aspetto": { "type": "string" },
              "aroma": { "type": "string" },
              "gusto": { "type": "string" },
              "retrogusto": { "type": "string" }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "brew_params" } } },
          "then": {
            "required": ["temp", "grams", "seconds", "infusions"],
            "properties": {
              "temp": { "type": "number" },
              "grams": { "type": "number" },
              "seconds": { "type": "number" },
              "infusions": { "type": "string" }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "equipment" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "items": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "steps" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": { "type": "string" },
                    "duration": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "errors" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "items": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "callout" } } },
          "then": {
            "required": ["variant", "spans"],
            "properties": {
              "variant": { "enum": ["italia", "warning", "tip"] },
              "spans": { "type": "array", "items": { "$ref": "#/$defs/span" } }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "pairings" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "items": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "faq" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["question", "answer_spans"],
                  "properties": {
                    "question": { "type": "string" },
                    "answer_spans": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/span" }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "related_links" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "url"],
                  "properties": {
                    "name": { "type": "string" },
                    "url": { "type": "string" },
                    "reason": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "level_section" } } },
          "then": {
            "required": ["level", "blocks"],
            "properties": {
              "level": { "enum": ["intro", "deep"] },
              "blocks": {
                "type": "array",
                "items": { "$ref": "#/$defs/block" }
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "positions" } } },
          "then": {
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["fonte", "tesi"],
                  "properties": {
                    "fonte": { "type": "string" },
                    "tesi": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
