        "blocks": [
          {
            "type": "paragraph",
            "spans": [
              {
                "type": "text",
                "value": "Stessa pianta, quantità di luce diversa: il sencha al sole è erba tagliata; il gyokuro all'ombra è brodo setoso; tra i due, il kabusecha impara a dividere il cielo."
              }
            ]
          },
          {
            "type": "paragraph",
            "spans": [
              {
                "type": "text",
                "value": "Durata: 40 minuti. Badge: Equilibrio ombra."
              }
            ]
          },
          {
            "type": "list",
            "ordered": false,
            "items": [
              {
                "spans": [
                  {
                    "type": "text",
                    "value": "Scala sole → ombra breve → ombra lunga"
                  }
                ]
              },
              {
                "spans": [
                  {
                    "type": "text",
                    "value": "Collegare tencha e matcha nella stessa filiera"
                  }
                ]
              },
              {
                "spans": [
                  {
                    "type": "text",
                    "value": "Adattare temperatura e dosaggio a ogni tappa"
                  }
                ]
              }
            ]
          }
        ]
