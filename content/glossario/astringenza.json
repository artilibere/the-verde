          },
          {
            "type": "faq",
            "items": [
              {
                "question": "L'astringenza è un difetto?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Non sempre. È un difetto se domina e nasconde aroma e dolcezza; può essere equilibrio in un verde strutturato."
                  }
                ]
              },
              {
                "question": "Astringenza e stomaco vuoto?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "I tannini su mucosa sensibile irritano: meglio bancha o genmaicha a digiuno, non gyokuro scottato."
                  }
                ]
              }
            ]
          },
