            "spans": [
              {
                "type": "text",
                "value": "Il bancha è il tè della frigo in bottiglia e della tavola familiare. Foglie più mature, sapore più rustico, caffeina contenuta: perfetto per chi inizia o per la sera."
              }
            ]
          }
        ]
      },
      {
        "type": "level_section",
        "level": "deep",
        "blocks": [
