            "items": [
              {
                "question": "Bancha è tè scadente?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "No. È una categoria voluta, con storia e uso quotidiano in Giappone."
                  }
                ]
              },
              {
                "question": "Bancha è tè scadente?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "No: è scelta di lavorazione e stagione — meno pregiato del sencha prima qualità, ma legittimo e delizioso."
