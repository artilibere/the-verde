                "reason": "diffusione mondiale"
              }
            ]
          },
          {
            "type": "faq",
            "items": [
              {
                "question": "Il tè verde è una pianta diversa dal tè nero?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "No: stessa Camellia sinensis. La differenza è nella lavorazione — il verde ferma l'ossidazione presto."
                  }
                ]
              }
            ]
          },
