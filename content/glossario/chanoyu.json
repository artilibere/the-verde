          {
            "type": "faq",
            "items": [
              {
                "question": "Chanoyu è per tutti?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "La forma completa richiede studio; il gesto consapevole è accessibile a casa."
                  }
                ]
              },
              {
                "question": "Chanoyu e cerimonia del tè cinese?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Tradizioni distinte: il chanoyu è giapponese con matcha; il gong fu cha cinese usa foglia intera e gaiwan — non confonderli."
                  }
                ]
              }
            ]
