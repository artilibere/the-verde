          {
            "type": "faq",
            "items": [
              {
                "question": "Posso usare la frusta da cucina?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Sconsigliato: il chasen incorpora aria senza graffiare."
                  }
                ]
              },
              {
                "question": "Posso usare un frullino elettrico?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Per cucina sì; per matcha tradizionale no — la schiuma del chasen ha texture e temperatura diverse."
                  }
                ]
              }
