          {
            "type": "faq",
            "items": [
              {
                "question": "Qualsiasi ciotola va bene?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Per cerimonia no; per casa sì, se larga e stabile per la frusta."
                  }
                ]
              },
              {
                "question": "Quale dimensione per iniziare?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Circa 12 cm di diametro per usucha: spazio sufficiente per il gesto del chasen senza schizzi."
                  }
                ]
              }
