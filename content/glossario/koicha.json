              {
                "question": "Koicha per principianti?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Meglio iniziare con usucha; il koicha è esperienza avanzata."
                  }
                ]
              },
              {
                "question": "Quanta polvere per il koicha?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Circa 4 g per 40 ml d'acqua tiepida — il doppio dell'usucha, con mescolatura lenta e senza schiuma grossolana."
