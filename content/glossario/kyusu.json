          {
            "type": "faq",
            "items": [
              {
                "question": "Kyusu solo per verde?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Principalmente sì; dedicare una teiera a un tipo di tè."
                  }
                ]
              },
              {
                "question": "Kyusu o tazza con infusore?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "L'infusore va bene; il kyusu distribuisce meglio la foglia e rende omaggio al gesto giapponese quotidiano."
                  }
                ]
              }
