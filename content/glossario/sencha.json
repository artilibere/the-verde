          {
            "type": "faq",
            "items": [
              {
                "question": "Sencha e gyokuro sono la stessa pianta?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Sì, stessa Camellia sinensis. Il gyokuro è ombreggiato prima del raccolto; il sencha cresce al sole."
                  }
                ]
              },
              {
                "question": "Sencha in bustina al supermercato?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Spesso polvere fine o tagli grossolani scadenti — non rappresenta il sencha specialty in foglia."
                  }
                ]
              }
            ]
