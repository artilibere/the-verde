            "spans": [
              {
                "type": "text",
                "value": "Lo shincha è la primavera in tazza: raccolto precoce, foglie tenere, aroma vivido che non aspetta. In Giappone è atteso come un evento stagionale."
              }
            ]
          }
        ]
      },
      {
        "type": "level_section",
        "level": "deep",
        "blocks": [
          {
            "type": "heading",
            "level": 2,
            "spans": [
