            "items": [
              {
                "question": "L'umami è solo giapponese?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Il concetto è giapponese; la sensazione compare anche in altri verdi ben fatti, ma è iconica nel gyokuro."
                  }
                ]
              },
              {
                "question": "Umami solo nel gyokuro?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Iconico lì, ma compare in matcha e sencha premium; raramente in gunpowder o hojicha tostato."
                  }
                ]
              }
