          {
            "type": "faq",
            "items": [
              {
                "question": "Tutto il tè verde è al vapore?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "No. Molti verdi cinesi usano padella; il vapore è dominante in Giappone."
                  }
                ]
              },
              {
                "question": "Vapore o padella: quale è «migliore»?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Nessuno vince: sono due estetiche. Il vapore esalta verde intenso; la padella cinese privilegia nocciola e morbidezza."
                  }
                ]
              }
            ]
