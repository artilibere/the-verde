          {
            "type": "faq",
            "items": [
              {
                "question": "Tutto il tè verde è al vapore?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "No. Molti verdi cinesi usano padella; il vapore è dominante in Giappone."
                  }
                ]
              }
