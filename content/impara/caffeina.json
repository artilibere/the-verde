            "type": "faq",
            "items": [
              {
                "question": "Tè verde decaffeinato?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Esiste, ma perde parte del profilo; spesso meglio hojicha naturale per la sera."
                  }
                ]
              },
              {
                "question": "Stomaco vuoto?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Tannini su stomaco sensibile possono irritare: inizia con bancha o genmaicha, non gyokuro a digiuno."
                  }
                ]
              }
            ]
