          {
            "type": "faq",
            "items": [
              {
                "question": "Posso praticare chanoyu in Italia?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Ci sono scuole e gruppi; anche senza sala formale puoi imparare usucha con matcha e chasen di qualità."
                  }
                ]
              },
              {
                "question": "Il rituale è religioso?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Ha radici zen; oggi molti lo vivono come estetica e presenza, non come dogma."
                  }
                ]
              }
            ]
