              {
                "question": "Tè verde in bustina: stessa lavorazione?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Spesso polvere o frammenti di bassa qualità, essiccazione industriale. Non rappresenta il verde specialty."
                  }
                ]
              },
              {
                "question": "La freschezza conta?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Sì. Catechine e aromi volatili degradano con il tempo; il verde di primavera (shincha) è atteso proprio per vivacità."
                  }
                ]
              }
