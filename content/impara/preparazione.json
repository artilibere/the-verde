          },
          {
            "type": "faq",
            "items": [
              {
                "question": "Devo pesare la foglia?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Per imparare sì; poi l'occhio basta. Un cucchiaino raso di sencha è circa 3 g — ma la bilancia insegna in una settimana."
                  }
                ]
              },
              {
                "question": "Posso reinfundere?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Molti verdi reggono 2–3 infusioni brevi; il profilo cambia a ogni versata. È parte del piacere del gong fu e del sencha in kyusu."
                  }
                ]
              }
            ]
          },
