          {
            "type": "faq",
            "items": [
              {
                "question": "Serve zucchero nel cold brew?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Di solito no: l'estrazione fredda esalta dolcezza naturale. Se aggiungi zucchero, stai creando una bibita — non c'è nulla di male, ma non è più «tè puro»."
                  }
                ]
              },
              {
                "question": "Hojicha o sencha per l'aperitivo?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Hojicha con stuzzichini salati e tostati; sencha o gyokuro cold brew con crudité e pesce leggero. Due registri, entrambi analcolici."
                  }
                ]
              }
            ]
          }
        ]
