            "type": "faq",
            "items": [
              {
                "question": "Il tè verde sostituisce il cappuccino?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "No — e non deve. È un'alternativa per chi cerca meno acidità o vuole variare; il caffè resta il rito italiano per eccellenza."
                  }
                ]
              },
              {
                "question": "Posso bere gyokuro a colazione?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Se tolleri la caffeina, sì — ma è un tè d'ombra intenso, meglio riservarlo a chi cerca concentrazione, non a chi vuole solo idratazione leggera."
                  }
                ]
              }
            ]
