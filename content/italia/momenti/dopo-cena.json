          {
            "type": "faq",
            "items": [
              {
                "question": "Posso sostituire il caffè ristretto?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Se cerchi meno caffeina e un profilo tostato, sì. Se ami l'intensità del caffè, l'hojicha non imita quella sensazione — offre un'altra esperienza."
                  }
                ]
              },
              {
                "question": "Il tè verde fa digerire?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Non ci sono evidenze solide da integratore. Bevi per piacere e calma; eventuali benefici digestivi restano tradizione, non promessa."
                  }
                ]
              }
            ]
          }
        ]
