            "type": "faq",
            "items": [
              {
                "question": "Il tè verde mi fa meno nervoso del caffè?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Per molti sì: L-teanina e caffeina convivono nella foglia e modulano la stimolazione. Non è una regola universale — dipende da sensibilità e dosaggio."
                  }
                ]
              },
              {
                "question": "Quante infusioni in pausa?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Un sencha regge 2–3 versate brevi: la seconda è spesso la più dolce. Ottimo pretesto per allungare la pausa senza aprire un'altra bustina."
                  }
                ]
              }
            ]
