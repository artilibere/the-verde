          {
            "type": "faq",
            "items": [
              {
                "question": "Quanto dura il cold brew in frigo?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Consumalo entro 24–48 ore per freschezza. Oltre, il profilo si appiattisce e può ossidarsi leggermente."
                  }
                ]
              },
              {
                "question": "Posso usare il tè in bustina freddo?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Puoi, ma la qualità della foglia conta: polvere fine o tagli grossolani danno profili piatti. Un sencha intero in foglia cambia l'esperienza."
                  }
                ]
              }
            ]
          }
        ]
