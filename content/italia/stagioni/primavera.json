          {
            "type": "faq",
            "items": [
              {
                "question": "Lo shincha vale il prezzo extra?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Per chi ama la freschezza del primo raccolto, sì — è un'esperienza limitata nel tempo. Per iniziare, un sencha di qualità costa meno e insegna lo stesso metodo."
                  }
                ]
              },
              {
                "question": "Quando passare al cold brew?",
                "answer_spans": [
                  {
                    "type": "text",
                    "value": "Quando le giornate si fanno calde — di solito da maggio in poi in Italia. Fino ad allora, goditi i verdi primaverili caldi a 70 °C."
                  }
                ]
              }
