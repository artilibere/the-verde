        "type": "faq",
        "items": [
          {
            "question": "Nilgiri verde e Nilgiri nero sono la stessa cosa?",
            "answer_spans": [
              {
                "type": "text",
                "value": "Stessa regione, lavorazioni diverse: il verde ortodosso è raro rispetto al CTC per chai."
