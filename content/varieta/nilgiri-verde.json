        "spans": [
          {
            "type": "text",
            "value": "Monti azzurri del Tamil Nadu: il Nilgiri verde profuma di verdure cotte e lime, liquore dorato leggero — l'India oltre il Darjeeling che già conosci."
          }
        ]
      },
