      {
        "type": "faq",
        "items": [
          {
            "question": "Perché «Hou Kui»?",
            "answer_spans": [
              {
                "type": "text",
                "value": "Leggenda del «primo tè delle scimmie»: hou significa scimmia, kui il primo — per l'area inaccessibile di raccolta."
              }
            ]
          },
          {
            "question": "Perché le venature rossastre?",
            "answer_spans": [
              {
                "type": "text",
                "value": "Effetto della pressatura in lavorazione; in infusione è normale e distintivo."
              }
            ]
          }
        ]
      },
